# ============================================================
# Variables de entorno - Proyecto Semestral ISY1101
# IMPORTANTE: Copiar este archivo a .env y completar los valores
# NUNCA subir el .env al repositorio (está en .gitignore)
# ============================================================

# Docker Hub
DOCKER_USERNAME=tu_usuario_dockerhub

# MySQL - Configuración compartida
MYSQL_ROOT_PASSWORD=un_password_seguro_aqui

# MySQL - Servicio Ventas
MYSQL_DB_VENTAS=ventas_db
MYSQL_USER_VENTAS=ventas_user
MYSQL_PASS_VENTAS=ventas_pass_seguro

# MySQL - Servicio Despachos
MYSQL_DB_DESPACHOS=despachos_db
MYSQL_USER_DESPACHOS=despachos_user
MYSQL_PASS_DESPACHOS=despachos_pass_seguro

# IP del EC2 Backend (para que el frontend sepa dónde conectarse)
EC2_BACKEND_IP=<IP_PUBLICA_EC2_BACKEND>
